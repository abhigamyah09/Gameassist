<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Hero -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hero_title"
            android:textColor="@color/brand_on_background"
            android:textSize="32sp"
            android:textStyle="bold"
            android:contentDescription="@string/hero_title" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/hero_subtitle"
            android:textColor="@color/brand_on_surface"
            android:textSize="14sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="20dp"
            android:background="#33FFFFFF" />

        <!-- Status chips -->
        <TextView
            android:id="@+id/status_accessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:textSize="14sp"
            xmlns:tools="http://schemas.android.com/tools"
            tools:text="@string/status_accessibility_missing" />

        <TextView
            android:id="@+id/status_overlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/status_capture"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:textSize="14sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="20dp"
            android:background="#33FFFFFF" />

        <!-- Steps -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/step_1_title"
            android:textColor="@color/brand_on_background"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/step_1_desc"
            android:textColor="@color/brand_on_surface"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btn_open_accessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/btn_open_accessibility" />

        <Space android:layout_width="match_parent" android:layout_height="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/step_2_title"
            android:textColor="@color/brand_on_background"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/step_2_desc"
            android:textColor="@color/brand_on_surface"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btn_open_overlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/btn_open_overlay" />

        <Space android:layout_width="match_parent" android:layout_height="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/step_3_title"
            android:textColor="@color/brand_on_background"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/step_3_desc"
            android:textColor="@color/brand_on_surface"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btn_start_capture"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/btn_start_capture" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="24dp"
            android:background="#33FFFFFF" />

        <Button
            android:id="@+id/btn_launch_demo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_launch_demo"
            android:backgroundTint="@color/brand_accent" />

        <Button
            android:id="@+id/btn_open_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/btn_open_settings"
            style="@style/Widget.Material3.Button.TextButton" />

    </LinearLayout>
</ScrollView>
