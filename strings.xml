<resources>
    <string name="app_name">GameAssist</string>
    <string name="settings_title">Settings</string>
    <string name="demo_game_title">Meteor Dodge (Demo)</string>

    <string name="accessibility_service_label">GameAssist — Accessibility Helper</string>
    <string name="accessibility_service_description">
        Assistive accessibility service for visually impaired and differently-abled gamers.
        Captures the screen, detects falling threats (meteors/fireballs), satellites/UFOs,
        and collectibles, then gently guides the player character away from danger and
        towards safe items by simulating human-like drag gestures.
    </string>

