    <!-- Settings -->
    <string name="pref_speed_title">Player move speed</string>
    <string name="pref_speed_desc">Max %1$.0f%% of screen width per second (human-like ≈ 25%)</string>
    <string name="pref_reaction_title">Reaction time (ms)</string>
    <string name="pref_reaction_desc">Delay between detection and gesture (100–200ms recommended)</string>
    <string name="pref_calib_duration_title">Calibration duration (sec)</string>
    <string name="pref_calib_duration_desc">How long to sample dominant colors at startup</string>
    <string name="pref_min_interval_title">Min gesture interval (ms)</string>
    <string name="pref_min_interval_desc">Avoids jitter — refuse injections newer than this</string>
    <string name="pref_vibrate_title">Vibrate on assist action</string>
    <string name="pref_vibrate_desc">Haptic feedback whenever a drag is injected</string>
    <string name="pref_talkback_title">Announce state via TalkBack</string>
    <string name="pref_talkback_desc">Reads out state changes for blind users</string>

    <!-- Demo game -->
    <string name="demo_instructions">
        Drag the white ship at the bottom to dodge red meteors and catch blue gems.
        Then toggle GameAssist on — it should move your ship for you.
    </string>
    <string name="demo_score">Score: %1$d</string>
