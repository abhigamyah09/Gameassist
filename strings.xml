    <string name="overlay_fab_on">Assist ON</string>
    <string name="overlay_fab_off">Assist OFF</string>
    <string name="overlay_status_idle">Idle</string>
    <string name="overlay_status_scanning">Scanning…</string>
    <string name="overlay_status_safe">Safe</string>
    <string name="overlay_status_threat_left">Threat ← Left</string>
    <string name="overlay_status_threat_right">Threat → Right</string>
    <string name="overlay_status_threat_center">Threat ↑ Center</string>
    <string name="overlay_status_collectible">Collectible nearby</string>
    <string name="overlay_status_calibrating">Calibrating…</string>

