    <string name="notif_channel_desc">Keeps the assist running while you play.</string>
    <string name="notif_title">GameAssist active</string>
    <string name="notif_text">Tap to open. Long-press the floating button to stop.</string>

    <!-- MainActivity -->
    <string name="hero_title">GameAssist</string>
    <string name="hero_subtitle">Accessibility Helper for gamers with motor disabilities</string>
    <string name="step_1_title">1. Grant Accessibility permission</string>
    <string name="step_1_desc">Required for the service to read the screen and inject drag gestures.</string>
    <string name="step_2_title">2. Grant Display over other apps</string>
    <string name="step_2_desc">Required for the floating ON/OFF button that works on top of any game.</string>
    <string name="step_3_title">3. Start screen capture</string>
    <string name="step_3_desc">Required for color detection. Tap the floating button to begin guiding.</string>
